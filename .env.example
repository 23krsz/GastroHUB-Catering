# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
ADMIN_CHAT_ID=

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=

# ── Strava OAuth ───────────────────────────────────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# ── Backend security ───────────────────────────────────────────────────────
INTERNAL_API_KEY=

# ── Public URL (ngrok / production) ─────────────────────────────────────────
BASE_URL=http://localhost:8000

# ── Ngrok (opsional, untuk dev lokal) ───────────────────────────────────────
NGROK_AUTHTOKEN=
NGROK_STATIC_DOMAIN=

# ── Kitchen dashboard ───────────────────────────────────────────────────────
# SHA-256 hash dari password dapur (bukan plaintext)
DASHBOARD_PASSWORD_HASH=

# ── Bot UX ──────────────────────────────────────────────────────────────────
UX_MODE=B
